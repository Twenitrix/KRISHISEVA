# ──────────────────────────────────────────────
# KRISHISEVA — Environment Variables
# Copy this file to .env and fill in real values
# ──────────────────────────────────────────────

# ── Application ──
APP_NAME=KRISHISEVA
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# ── Database ──
DATABASE_URL=postgresql+asyncpg://krishiseva:krishiseva_secret@db:5432/krishiseva
DATABASE_ECHO=false

# ── Auth / JWT ──
JWT_SECRET_KEY=change-this-to-a-strong-random-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── AI / NVIDIA API ──
NVIDIA_API_KEY=nvapi-your-key-here
NVIDIA_API_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_VISION_MODEL=meta/llama-4-maverick-17b-128e-instruct

# ── Aadhaar Mock Service ──
AADHAAR_SERVICE_URL=http://mock-aadhaar:8001

# ── File Uploads ──
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# ── CORS ──
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
